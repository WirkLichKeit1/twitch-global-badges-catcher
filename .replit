entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["tk", "xorg.libX11", "python3Full"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "run"
mode = "sequential"
author = 48223061

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python script.py"

[[workflows.workflow]]
name = "teste"
mode = "sequential"
author = 48223061

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python teste.py"

[[workflows.workflow]]
name = "teste"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=\"/nix/profile/default/bin:$PATH\" python3 teste.py"

[[ports]]
localPort = 8080
externalPort = 80
